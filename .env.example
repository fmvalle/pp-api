# Cloud Run define PORT no contentor (ex. 8080). O Dockerfile da API usa essa variável no uvicorn.
# Não fixes a porta só no Cloud Console sem alinhar com o que o processo escuta.

DATABASE_URL=postgresql+asyncpg://postgres:postgres@bo.curricularlab.com.br:5432/pp_db
JWT_SECRET=change-me-use-at-least-32-chars-long-secret
REFRESH_TOKEN_PEPPER=change-me-pepper-at-least-16
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30
# Firebase Admin SDK (mesmo projeto que o app / ava).
#
# Cloud Run ou Docker: montar o JSON em /secrets/firebase-admin.json no contentor.
# FIREBASE_CREDENTIALS_PATH=/secrets/firebase-admin.json
#
# uvicorn local (pasta api/): copiar o ficheiro a partir do pp-bo (fica uma cópia;
# não removes o original). Ajusta o caminho de origem se o clone estiver doutro sítio:
#   mkdir -p secrets && cp ../pp-bo/secrets/firebase-admin.json secrets/
# FIREBASE_CREDENTIALS_PATH=./secrets/firebase-admin.json
#
# Alternativa sem cópia: apontar para o JSON no repo pp-bo (caminho absoluto).
FIREBASE_CREDENTIALS_PATH=./secrets/firebase-admin.json
FIREBASE_PROJECT_ID=parametro-pedagogico
# Chave Web (Firebase Console → definições do projeto → Geral → apps Web) — necessária para
# POST /v1/auth/sign-in e POST /api/v1/auth/sign-in (email + senha na API, Identity Toolkit).
# FIREBASE_WEB_API_KEY=AIza...
# Em alternativa ao JSON (ex.: Cloud Run como Directus): email + PEM numa linha com \n escapados.
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@parametro-pedagogico.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n
FIREBASE_CHECK_REVOKED=false
API_DEBUG=false
# CSV de origens exatas. Não use http://localhost:* (inválido no CORS). Qualquer porta em localhost/127:
# CORS_ALLOW_LOCALHOST_ANY_PORT=true (padrão) + allow_origin_regex no Starlette.
# Se POST falhar no Flutter Web com "Failed to fetch" mas GET funcionar: confira na aba Network o Origin
# (deve ser o mesmo host que abre o app, ex. não misturar localhost com 127.0.0.1). A API adiciona
# Access-Control-Allow-Private-Network no preflight para Chrome aceder a localhost.
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500
CORS_ALLOW_LOCALHOST_ANY_PORT=true
# Regex opcional; se preenchido, substitui o regex automático de localhost.
# CORS_ORIGIN_REGEX=

# --- Storage (uploads de lista de presença + PDF consolidado macro×escola) ---
# local = disco em ATTENDANCE_SHEET_STORAGE_PATH (padrão var/attendance_sheets)
# gcs   = bucket GCS (obrigatório GCS_ATTENDANCE_SHEETS_BUCKET)
#
# Exemplo produção (bucket storage-pp-admin):
#   https://console.cloud.google.com/storage/browser/storage-pp-admin
#   gs://storage-pp-admin/pp-admin/{storage_key}
ATTENDANCE_SHEET_STORAGE_BACKEND=local
ATTENDANCE_SHEET_STORAGE_PATH=var/attendance_sheets
# ATTENDANCE_SHEET_STORAGE_BACKEND=gcs
# GCS_ATTENDANCE_SHEETS_BUCKET=storage-pp-admin
# GCS_ATTENDANCE_SHEETS_PREFIX=pp-admin
# GCS_CREDENTIALS_JSON=
# GOOGLE_APPLICATION_CREDENTIALS=./secrets/gcs-service-account.json

# --- Assistente IA (Avaliador) — opcional ---
# ASSISTANT_OPENAI_API_KEY=sk-...
# ASSISTANT_OPENAI_MODEL=gpt-4o-mini
# ASSISTANT_OPENAI_BASE_URL=https://api.openai.com/v1
